# Postgres connection string. On Neon, copy the "pooled connection" string from your
# project dashboard. Works locally too with any Postgres instance.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Optional: leave unset for no login (default). If set, the app will prompt for this
# single shared password before allowing access. (Hook is in place but disabled by default.)
# APP_PASSWORD=
